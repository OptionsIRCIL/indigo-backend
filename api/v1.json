{
  "openapi": "3.1.0",
  "info": {
    "title": "Indigo REST API",
    "description": "Documentation for interacting with OptionsIRCIL/indigo-backend over HTTP.",
    "version": "0.0.0"
  },
  "servers": [
    {
      "url": "http://acm.cs.und.edu:58080/api/v1",
      "description": "CI sandbox"
    },
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local development"
    }
  ],
  "paths": {
    "/auth": {
      "post": {
        "summary": "/auth",
        "security": [],
        "description": "Authenticate against LDAP to request an authentication token.",
        "requestBody": {
          "content": {
            "application/json": {
              "required": true,
              "schema": {
                "$ref": "#/components/schemas/AuthenticationCredentials"
              },
              "examples": {
                "default": {
                  "summary": "Authentication payload",
                  "value": {
                    "username": "john.doe",
                    "password": "correct horse battery staple"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Credentials accepted"
          },
          "422": {
            "description": "Credentials rejected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HandledError"
                },
                "examples": {
                  "default": {
                    "summary": "Incorrect credentials",
                    "value": {
                      "status": 422,
                      "message": "Invalid credentials"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "'Hello World' endpoint.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Hello": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Response for user with name John Doe",
                    "value": {
                      "Hello": "John"
                    }
                  }
                }
              }
            },
            "description": "Successful authenticated response"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthenticationCredentials": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "HandledError": {
        "type": "object",
        "properties": {
          "status": {
            "type": "int"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "indigo-token"
      }
    }
  },
  "security": [
    {
      "cookieAuth": []
    }
  ]
}
